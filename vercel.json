{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/product",
      "destination": "/selective-math-pack",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/ch_tuition_storefront_desktop/"
    },
    {
      "source": "/selective-math-pack",
      "destination": "/ch_tuition_storefront_desktop/product"
    },
    {
      "source": "/privacy",
      "destination": "/ch_tuition_storefront_desktop/privacy"
    },
    {
      "source": "/terms",
      "destination": "/ch_tuition_storefront_desktop/terms"
    },
    {
      "source": "/(.*)",
      "destination": "/ch_tuition_storefront_desktop/$1"
    }
  ]
}
